{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "isolatedModules": true
  },
  "exclude": ["node_modules", "dist"],
  "include": [
    "./*.ts",
    "./__helpers/**/*.ts"
  ]
}
