                  "configuration/collections",
                  "configuration/environment-vars",
                  "configuration/ai",
                  "configuration/agents"
                ]
              },
              {
                "group": "Database",
                "expanded": false,
                "pages": [
                  "database/overview",
                  "database/mongodb",
                  "database/postgres",
                  "database/sqlite",
                  "database/migrations",
                  "database/transactions",
                  "database/indexes"
                ]
              },
              {
                "group": "Access Control",
                "expanded": false,
                "pages": [
                  "access-control/overview",
                  "access-control/collections",
                  "access-control/fields",
                  "access-control/globals"
                ]
              },
              {
