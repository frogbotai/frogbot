                "group": "REST API",
                "expanded": false,
                "pages": ["rest-api/overview"]
              },
              {
                "group": "GraphQL",
                "expanded": false,
                "pages": [
                  "graphql/overview",
                  "graphql/graphql-schema",
                  "graphql/extending"
                ]
              },
              {
                "group": "Queries",
                "expanded": false,
                "pages": [
                  "queries/overview",
                  "queries/depth",
                  "queries/pagination",
                  "queries/select",
                  "queries/sort"
