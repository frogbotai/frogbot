{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Frogbot Docs",
  "api": {
    "mdx": {
      "server": "https://app.frogbot.ai/api",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "colors": {
    "primary": "#030712",
    "light": "#F9FAFB",
    "dark": "#3acf6a"
  },
  "favicon": "/favicon.svg",
