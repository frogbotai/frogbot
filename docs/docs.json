          },
          {
            "group": "Features",
            "pages": [
              { "group": "Authentication", "expanded": false, "pages": ["authentication/overview", "authentication/operations", "authentication/jwt", "authentication/cookies", "authentication/email", "authentication/api-keys", "authentication/token-data", "authentication/custom-strategies"]},
              { "group": "Chat", "expanded": false, "pages": ["chat/overview"]},
              { "group": "Versions", "expanded": false, "pages": ["versions/overview", "versions/drafts", "versions/autosave"]},
              { "group": "Email", "expanded": false, "pages": ["email/overview"]},
              { "group": "Trash", "expanded": false, "pages": ["trash/overview"]},
              { "group": "Troubleshooting", "expanded": false, "pages": ["troubleshooting/troubleshooting"]},
              { "group": "Typescript", "expanded": false, "pages": ["typescript/overview", "typescript/generating-types", "typescript/ts-plugin"]}
           ]
          },
          {
            "group": "Ecosystem",
            "pages": [
              { "group": "Plugins", "expanded": false, "pages": ["plugins/overview", "plugins/rag", "plugins/build-your-own", "plugins/plugin-api"]},
