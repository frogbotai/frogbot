{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "frogbot-gateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "FrogBot Gateway (local)",
      "options": {
        "baseURL": "http://localhost:3939/v1",
        "apiKey": "local"
      },
      "models": {
        "amazon-bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0": {
          "name": "Claude Sonnet 4.5 (Bedrock)",
          "tool_call": true,
          "reasoning": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "amazon-bedrock/us.anthropic.claude-sonnet-4-20250514-v1:0": {
          "name": "Claude Sonnet 4 (Bedrock)",
          "tool_call": true,
          "reasoning": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "amazon-bedrock/us.anthropic.claude-opus-4-20250514-v1:0": {
          "name": "Claude Opus 4 (Bedrock)",
          "tool_call": true,
          "reasoning": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "amazon-bedrock/us.amazon.nova-pro-v1:0": {
          "name": "Nova Pro (Bedrock)",
          "tool_call": true,
          "limit": { "context": 300000, "output": 5000 }
        },
        "anthropic/claude-sonnet-4-5-20250929": {
          "name": "Claude Sonnet 4.5 (direct Anthropic)",
          "tool_call": true,
          "reasoning": true,
          "limit": { "context": 200000, "output": 64000 }
        },
        "openai/gpt-5": {
          "name": "GPT-5 (direct OpenAI)",
          "tool_call": true,
          "reasoning": true,
          "limit": { "context": 400000, "output": 128000 }
        },
        "fireworks/accounts/fireworks/models/kimi-k2-instruct": {
          "name": "Kimi K2 (Fireworks)",
          "tool_call": true,
          "limit": { "context": 128000, "output": 16384 }
        },
        "ollama/llama3.2": {
          "name": "Llama 3.2 (self-hosted via Ollama)",
          "tool_call": true,
          "limit": { "context": 128000, "output": 4096 }
        }
      }
    }
  }
}
