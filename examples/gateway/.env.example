# --- AWS Bedrock (use ONE of the two auth modes) ---
# SigV4 (static or SSO/temporary creds — add AWS_SESSION_TOKEN for SSO):
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# ...or Bedrock API key (bearer) mode — simplest, region defaults to us-east-1:
AWS_BEARER_TOKEN_BEDROCK=

# --- Direct provider slots (each optional; a provider is skipped if unset) ---
# Direct Anthropic — the path where reasoning_effort maps to extended thinking.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FIREWORKS_API_KEY=

# --- Self-hosted / OpenAI-compatible ---
OLLAMA_BASE_URL=http://localhost:11434/v1

PORT=3939
