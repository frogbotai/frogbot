# FrogBot needs an OpenAI key to run this example's `assistant` agent
# (model: openai/gpt-4o-mini). Swap the provider/model in frogbot.config.ts
# if you'd rather use anthropic, google, groq, etc.
OPENAI_API_KEY=

# Any random string works for local dev. Change this before deploying.
FROGBOT_SECRET=dev-secret-change-me

# SQLite file path (libsql URL format). The default creates a local file
# next to this config — no external database required.
DATABASE_URL=file:./frogbot.db

# Port for the Hono server started by `frogbot start` / `frogbot dev`.
PORT=3000
