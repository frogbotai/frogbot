{
  "name": "frogbot",
  "version": "0.0.1",
  "description": "FrogBot core: typed configuration surface that wraps Payload.",
  "license": "MIT",
  "author": "Colby Gilbert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frogbotai/frogbot.git",
    "directory": "packages/frogbot"
  },
  "homepage": "https://github.com/frogbotai/frogbot#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/exports/server.d.ts",
      "import": "./dist/exports/server.js",
      "default": "./dist/exports/server.js"
    },
    "./test": {
      "types": "./dist/exports/test.d.ts",
      "import": "./dist/exports/test.js",
      "default": "./dist/exports/test.js"
    }
  },
  "bin": {
    "frogbot": "./bin.js"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x bin.js",
    "clean": "rm -rf dist",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@frogbotai/gateway": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@payloadcms/translations": "3.85.1",
    "ai": "^7.0.4",
    "hono": "^4.6.14",
    "json-schema-to-typescript": "^15.0.3",
    "payload": "3.85.1",
    "tsx": "^4.19.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@ai-sdk/otel": "^1.0.31",
    "next": "^15.4.10"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/otel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@frogbotai/eslint-config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "next": "15.4.10",
    "typescript": "5.6.2"
  }
}
