{
  "name": "@frogbot/db-mongodb",
  "version": "0.0.0",
  "description": "FrogBot MongoDB adapter.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.85.1"
  },
  "peerDependencies": {
    "frogbot": "workspace:*"
  },
  "devDependencies": {
    "frogbot": "workspace:*",
    "typescript": "5.6.2"
  }
}
