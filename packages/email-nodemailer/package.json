{
  "name": "@frogbotai/email-nodemailer",
  "version": "0.2.1",
  "description": "Nodemailer email adapter for FrogBot.",
  "license": "MIT",
  "author": "Colby Gilbert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frogbotai/frogbot.git",
    "directory": "packages/email-nodemailer"
  },
  "homepage": "https://github.com/frogbotai/frogbot#readme",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/email-nodemailer": "3.85.1"
  },
  "peerDependencies": {
    "frogbot": "workspace:*"
  },
  "devDependencies": {
    "frogbot": "workspace:*",
    "typescript": "5.6.2"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
