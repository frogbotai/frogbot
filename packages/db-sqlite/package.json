{
  "name": "@frogbotai/db-sqlite",
  "version": "0.1.0",
  "description": "FrogBot SQLite adapter.",
  "license": "MIT",
  "author": "Colby Gilbert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frogbotai/frogbot.git",
    "directory": "packages/db-sqlite"
  },
  "homepage": "https://github.com/frogbotai/frogbot#readme",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./drizzle": {
      "import": "./src/drizzle.ts",
      "types": "./src/drizzle.ts",
      "default": "./src/drizzle.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.85.1",
    "drizzle-orm": "0.45.2"
  },
  "peerDependencies": {
    "frogbot": "workspace:*"
  },
  "devDependencies": {
    "frogbot": "workspace:*",
    "typescript": "5.6.2"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./drizzle": {
        "import": "./dist/drizzle.js",
        "types": "./dist/drizzle.d.ts",
        "default": "./dist/drizzle.js"
      }
    }
  }
}
